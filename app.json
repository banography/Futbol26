{
  "expo": {
    "name": "Futbol26",
    "slug": "futbol26",
    "scheme": "futbol26",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bani.futbol26",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bani.futbol26",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f1e"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f1e",
          "image": "./assets/splash.png",
          "resizeMode": "cover"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2af7f107-b773-48da-8d8a-cb77ce42596a"
      }
    }
  }
}
